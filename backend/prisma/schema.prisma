// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum WorkspaceRole {
  OWNER
  MEMBER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

model Workspace {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String?

  boards      Board[]
  announcements Announcement[]
  messages    ChatMessage[]
  memberships WorkspaceMember[]
  invitations Invitation[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WorkspaceMember {
  id          String        @id @default(uuid()) @db.Uuid
  role        WorkspaceRole @default(MEMBER)

  workspaceId String        @db.Uuid
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  userId      String        @db.Uuid
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

model Invitation {
  id          String           @id @default(uuid()) @db.Uuid
  email       String           @db.Text
  status      InvitationStatus @default(PENDING)
  expiresAt   DateTime

  workspaceId  String    @db.Uuid
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  invitedById String  @db.Uuid
  invitedBy   User    @relation("SentInvitations", fields: [invitedById], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@index([email])
}

model Board {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  description String?

  workspaceId String    @db.Uuid
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  lists       List[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workspaceId])
}

model List {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  position  Int

  boardId   String   @db.Uuid
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)

  tasks     Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([boardId])
  @@index([boardId, position])
}

model Task {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  description String?
  position    Int
  dueDate     DateTime? @db.Date

  listId      String    @db.Uuid
  list        List      @relation(fields: [listId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  comments    TaskComment[]
  attachments Attachment[]

  @@index([listId])
  @@index([listId, position])
}

model User {
  id                   String            @id @db.Uuid
  email                String?           @db.Text
  fullName             String?           @db.Text
  avatarUrl            String?           @db.Text
  rawUserMeta          Json?

  workspaceMemberships WorkspaceMember[]
  announcements        Announcement[]
  messages             ChatMessage[]
  attachments          Attachment[]
  taskComments         TaskComment[]
  recentVisits         RecentVisit[]
  sentInvitations      Invitation[]      @relation("SentInvitations")

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Announcement {
  id          String    @id @default(uuid()) @db.Uuid
  title       String
  content     String
  pinned      Boolean   @default(false)

  authorId    String    @db.Uuid
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)

  workspaceId String    @db.Uuid
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  attachments Attachment[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workspaceId])
}

model ChatMessage {
  id          String   @id @default(uuid()) @db.Uuid
  content     String   @db.Text

  authorId    String   @db.Uuid
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  workspaceId String   @db.Uuid
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workspaceId, createdAt])
}

model TaskComment {
  id        String   @id @default(uuid()) @db.Uuid
  content   String   @db.Text

  authorId  String   @db.Uuid
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  taskId    String   @db.Uuid
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId, createdAt])
}

model RecentVisit {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  entityType  String   @db.VarChar(20)
  entityId    String   @db.Uuid
  visitedAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, entityType, entityId])
  @@index([userId, entityType, visitedAt])
}

// Files attached to an entity. Exclusive belongs-to: exactly one parent FK is set
// (enforced at the API layer).
model Attachment {
  id              String        @id @default(uuid()) @db.Uuid
  fileName        String        @db.Text
  fileSize        Int
  mimeType        String        @db.Text
  storagePath     String        @db.Text

  announcementId  String?       @db.Uuid
  announcement    Announcement? @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  taskId          String?       @db.Uuid
  task            Task?         @relation(fields: [taskId], references: [id], onDelete: Cascade)

  uploadedById    String        @db.Uuid
  uploadedBy      User          @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([announcementId])
  @@index([taskId])
  @@index([uploadedById])
}
